# OpenCode server
# Required for preflight / server auth:
OPENCODE_SERVER_PASSWORD=change-me
OPENCODE_SERVER_USERNAME=opencode
CONFIG_REPO=https://github.com/roborew/opencode.git
CONFIG_REF=main

# Host port publishing (compose defaults after :- if unset)
# Host publish port (must match container listen port; avoid 4096 — Kilo uses it)
OPENCODE_PUBLISH_PORT=4097
# MCP OAuth callback (browser → host → container). Default compose bind is
# 127.0.0.1:19876 (not public). On DigitalOcean, SSH-tunnel from your laptop:
#   ssh -N -L 19876:127.0.0.1:19876 user@droplet
OPENCODE_OAUTH_CALLBACK_PUBLISH=127.0.0.1:19876
MILVUS_PUBLISH_PORT=19530
MILVUS_HEALTH_PUBLISH_PORT=9091
MINIO_API_PUBLISH_PORT=19000
MINIO_CONSOLE_PUBLISH_PORT=19001

# Twingate (local fallback; deployed via Infisical)
TWINGATE_NETWORK=
TWINGATE_ACCESS_TOKEN=
TWINGATE_REFRESH_TOKEN=

# OpenCode / providers (local fallback; deployed via Infisical)
# OPENROUTER_API_KEY — model provider (preflight warns if missing)
OPENROUTER_API_KEY=
# GH_ORG + GH_TOKEN — required for ./scripts/setup.sh projects github
# Prefer a fine-grained PAT (github_pat_*). See README "GitHub token" for
# repository + organization permissions. Classic alternative: repo + read:org.
GH_ORG=
GH_PROJECT=
GH_TOKEN=

# CodeRabbit CLI (agent code review in container)
# Agentic API key from CodeRabbit dashboard → API Keys (requires Usage-based Add-on)
CODERABBIT_API_KEY=

# claude-context / Milvus
# OPENAI_API_KEY — embeddings for claude-context MCP (preflight warns if missing)
# Compose profile: keep "milvus" enabled for indexing; clear COMPOSE_PROFILES to
# skip etcd/minio/milvus and free RAM when you only need the OpenCode server.
COMPOSE_PROFILES=milvus
MILVUS_TOKEN=local
OPENAI_API_KEY=
EMBEDDING_PROVIDER=OpenAI

# docs-mcp-server (host or LAN — container cannot use 127.0.0.1)
# Same machine: http://host.docker.internal:6280/sse
# Other LAN host: http://192.168.x.x:6280/sse
DOCS_MCP_URL=http://host.docker.internal:6280/sse

# Loopback URL rewrite inside the container (webfetch, curl in bash, etc.)
# localhost / 127.0.0.1 / [::1] → DOCKER_HOST_INTERNAL before tools run
DOCKER_HOST_INTERNAL=host.docker.internal
LOCALHOST_REWRITE=1

# 1Password SSH agent (git signing / GitHub SSH in container)
# Quote path — it contains spaces
SSH_AUTH_SOCK=

# Infisical runtime injection (set in deployed environments;
# leave blank locally to use .env values directly)
INFISICAL_PROJECT_ID=
INFISICAL_ENV=dev
INFISICAL_DOMAIN=https://eu.infisical.com
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_TOKEN=
INFISICAL_USE_CLI=true

# Optional paths
# Host directory of git repos — same-path bind into the container (absolute path;
# Docker does not expand ~). OpenCode registers projects at this path so git/Tower
# worktree links use local paths.
# Examples: /Users/you/projects  or  /data/opencode/apps
OPENCODE_APPS_DIR=
# Host path for OpenCode workspace worktrees (absolute; must end with /opencode/worktree).
# Same-path bind; XDG is aligned so OpenCode creates worktrees here (Desktop default:
# ~/.local/share/opencode/worktree). Chats/sessions stay on the opencode-data volume.
# Examples: /Users/you/.local/share/opencode/worktree
OPENCODE_WORKTREES_DIR=
DOCKER_VOLUME_DIRECTORY=../milvus

# Canonical hostname for Twingate clients (setup can map this to 127.0.0.1 on the host)
OPENCODE_FQDN=opencode.home.internal
# Post-compose setup: ./scripts/setup.sh
#   preflight + project sync + /etc/hosts
# Does not configure or modify OpenCode.app.
# MCP OAuth: browser must reach host 127.0.0.1:19876 (published + socat bridge).
# Local host: open the printed URL. Remote host: ssh -N -L 19876:127.0.0.1:19876 user@host
# then docker exec -it opencode-server opencode mcp auth <name>
