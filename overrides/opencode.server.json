{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "/workspace/**": "allow",
      "/var/opencode-xdg/opencode/worktree/**": "allow"
    }
  },
  "mcp": {
    "docs-mcp-server": {
      "enabled": true,
      "url": "http://host.docker.internal:6280/sse"
    },
    "augment-context-engine": {
      "enabled": false
    },
    "auggie": {
      "enabled": false
    },
    "claude-context": {
      "type": "local",
      "enabled": true,
      "command": ["claude-context-mcp"],
      "timeout": 120000,
      "environment": {
        "OPENAI_API_KEY": "{env:OPENAI_API_KEY}",
        "MILVUS_ADDRESS": "{env:MILVUS_ADDRESS}",
        "MILVUS_TOKEN": "{env:MILVUS_TOKEN}",
        "EMBEDDING_PROVIDER": "{env:EMBEDDING_PROVIDER}"
      }
    }
  }
}
