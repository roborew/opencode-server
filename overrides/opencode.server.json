{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "/workspace/**": "allow"
    }
  },
  "mcp": {
    "docs-mcp-server": {
      "enabled": false
    },
    "augment-context-engine": {
      "enabled": false
    },
    "auggie": {
      "enabled": false
    },
    "claude-context": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "-y", "@zilliz/claude-context-mcp@latest"]
    }
  }
}
